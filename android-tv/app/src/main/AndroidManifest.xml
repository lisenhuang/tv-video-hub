<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Needed to launch the package installer for self-update (API 23+). -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <!-- Offline download foreground service + its progress notification. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- TV apps run without a touchscreen and use the leanback UI. -->
    <uses-feature
        android:name="android.software.leanback"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <!--
        usesCleartextTraffic=true: allow plain http:// backends, not just https://.
        The app targets user-controlled backends that are commonly run on a home LAN
        (a PC / OpenWRT router) reachable only by private IP with no TLS cert, e.g.
        http://192.168.1.50:8080. Android blocks cleartext by default once targetSdk>=28,
        which would make that setup unusable. Permitting cleartext app-wide keeps the
        LAN flow working; https remains fully supported and is recommended for any
        server reachable over the public internet (see the root README "Where to run it").
    -->
    <application
        android:name=".MediaHubApp"
        android:allowBackup="true"
        android:banner="@drawable/app_banner"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.TvVideoHub"
        android:usesCleartextTraffic="true"
        tools:targetApi="23">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:banner="@drawable/app_banner"
            android:label="@string/app_name"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.TvVideoHub">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <!-- LAUNCHER: shows in the phone/tablet app drawer. -->
                <category android:name="android.intent.category.LAUNCHER" />
                <!-- LEANBACK_LAUNCHER: shows on the Android TV home row.
                     Including both makes one APK launch on phones AND TVs. -->
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".player.PlayerActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden|navigation"
            android:launchMode="singleTop"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.TvVideoHub.Player" />

        <activity
            android:name=".ui.DetailActivity"
            android:exported="false"
            android:theme="@style/Theme.TvVideoHub" />
        <activity
            android:name=".ui.DownloadsActivity"
            android:exported="false"
            android:theme="@style/Theme.TvVideoHub" />
        <activity
            android:name=".ui.SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.TvVideoHub" />
        <activity
            android:name=".ui.StorageActivity"
            android:exported="false"
            android:theme="@style/Theme.TvVideoHub" />

        <!-- Foreground service that runs offline downloads (Media3 DownloadManager).
             The RESTART intent lets it resume downloads after the process is recreated. -->
        <service
            android:name=".download.MediaDownloadService"
            android:exported="false"
            android:foregroundServiceType="dataSync">
            <intent-filter>
                <action android:name="androidx.media3.exoplayer.downloadService.action.RESTART" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </service>

        <!-- FileProvider to hand the downloaded APK to the package installer on API 24+. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Relaunch the app automatically right after a self-update is installed.
             MY_PACKAGE_REPLACED is a protected system broadcast sent only to this app. -->
        <receiver
            android:name=".update.RestartOnUpdateReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>

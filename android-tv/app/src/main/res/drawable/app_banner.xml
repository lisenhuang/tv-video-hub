<?xml version="1.0" encoding="utf-8"?>
<!--
  TV launcher banner (recommended 320x180). Drawn as a vector so no binary PNG is
  needed. A dark card with a play-triangle glyph and the app initials.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="320dp"
    android:height="180dp"
    android:viewportWidth="320"
    android:viewportHeight="180">

    <!-- Background -->
    <path
        android:fillColor="#0E1116"
        android:pathData="M0,0 L320,0 L320,180 L0,180 Z" />

    <!-- Accent bar -->
    <path
        android:fillColor="#3D7BFF"
        android:pathData="M0,0 L320,0 L320,8 L0,8 Z" />

    <!-- Play circle -->
    <path
        android:fillColor="#1B2230"
        android:pathData="M90,90 m-44,0 a44,44 0 1,0 88,0 a44,44 0 1,0 -88,0" />

    <!-- Play triangle -->
    <path
        android:fillColor="#3D7BFF"
        android:pathData="M76,68 L116,90 L76,112 Z" />

    <!-- Wordmark blocks (decorative) -->
    <path
        android:fillColor="#E6EAF2"
        android:pathData="M168,74 L292,74 L292,86 L168,86 Z" />
    <path
        android:fillColor="#8893A7"
        android:pathData="M168,98 L256,98 L256,108 L168,108 Z" />
</vector>

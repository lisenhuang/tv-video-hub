# Android / Gradle ignores, scoped to android-tv/.
# (The repo root has a separate .NET .gitignore for backend/.)

# Build output
/build/
**/build/
/app/build/

# Gradle
.gradle/
**/.gradle/
local.properties

# Generated wrapper artifacts (regenerated by `gradle wrapper` in CI / locally).
# We DO commit gradle/wrapper/gradle-wrapper.properties.
/gradlew
/gradlew.bat
gradle/wrapper/gradle-wrapper.jar

# Android Studio / IntelliJ
.idea/
*.iml
.DS_Store
captures/
.externalNativeBuild/
.cxx/

# Keystores / secrets — never commit
*.jks
*.keystore
keystore.properties
signing.properties

# Logs
*.log

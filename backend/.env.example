# ALL of this is OPTIONAL. The app boots with ZERO env and is configured entirely
# in the /admin dashboard (persisted to App_Data/settings.json). These vars are only
# OPTIONAL seeds/defaults if you prefer to pre-fill some config. Never commit .env.

# --- Database (pluggable: d1 | sqlite | postgres | mysql | sqlserver) ---
# Leave empty to configure in the dashboard. Examples:
#   D1:     Database__Provider=d1 + the Cloudflare vars below
#   SQLite: Database__Provider=sqlite, Database__ConnectionString=Data Source=App_Data/mediahub.db
DATABASE_PROVIDER=
DATABASE_CONNECTION_STRING=

# D1-only fields (used when DATABASE_PROVIDER=d1)
CF_ACCOUNT_ID=
CF_D1_DATABASE_ID=
CF_D1_API_TOKEN=

# --- Object storage: any S3-compatible store (R2, AWS S3, MinIO, B2, ...) ---
# R2 (default): ServiceUrl=https://<acct>.r2.cloudflarestorage.com, Region=auto, ForcePathStyle=true
# AWS S3:       ServiceUrl= (empty),                                Region=us-east-1, ForcePathStyle=false
# MinIO:        ServiceUrl=http://minio:9000,                       Region=us-east-1, ForcePathStyle=true
STORAGE_SERVICE_URL=
STORAGE_REGION=auto
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_VIDEO_BUCKET=videos
STORAGE_APK_BUCKET=apks
STORAGE_FORCE_PATH_STYLE=true

# Release write secret (X-Api-Key). Can also be set in the dashboard.
API_KEY=

# OPTIONAL. The app boots with ZERO env and is configured at /admin. The ONLY thing
# that can be seeded via env is the DATABASE connection — the admin account, object
# storage, and the release API key live IN THE DATABASE (set them in the dashboard).
# Never commit a real .env.

# --- Database (pluggable: d1 | sqlite | postgres | mysql | sqlserver) ---
# Leave empty to configure in the dashboard. Examples:
#   D1:     Database__Provider=d1 + the Cloudflare vars below
#   SQLite: Database__Provider=sqlite, Database__ConnectionString=Data Source=App_Data/mediahub.db
DATABASE_PROVIDER=
DATABASE_CONNECTION_STRING=

# D1-only fields (used when DATABASE_PROVIDER=d1)
CF_ACCOUNT_ID=
CF_D1_DATABASE_ID=
CF_D1_API_TOKEN=

# (Object storage + release API key are NOT env vars anymore — configure them at /admin;
#  they are stored in the database.)
